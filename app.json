{
  "expo": {
    "name": "ChadV2",
    "slug": "ChadV2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "audio"
        ],
        "NSMicrophoneUsageDescription": "Chad listens for 'Hey Chad' to log your sets hands-free.",
        "NSSpeechRecognitionUsageDescription": "Chad uses speech recognition to detect 'Hey Chad' and transcribe your workout sets.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.habibooo.ChadV2"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio",
      "expo-speech-recognition"
    ],
    "extra": {
      "eas": {
        "projectId": "64874b5b-d5e5-404b-abf1-843cb456d754"
      }
    },
    "owner": "habibooo"
  }
}
